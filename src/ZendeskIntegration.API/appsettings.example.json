{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=ZendeskIntegration;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;"
  },
  "Zendesk": {
    "Subdomain": "mycompany",
    "AgentEmail": "agent@mycompany.com",
    "ApiToken": "<zendesk-api-token-from-admin-panel>",
    "JwtSecret": "<min-32-char-shared-secret-from-zendesk-messaging>",
    "JwtKeyId": "<key-id-from-zendesk-messaging-integration>",
    "JwtAlgorithm": "HS256",
    "JwtExpiryMinutes": 60
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
